# Copy this file to .env and fill in real values. .env is gitignored and must
# never be committed - it holds email credentials if you enable notifications.

# sam.gov search settings (a real API key is not needed - data comes from
# sam.gov's own internal search UI, driven through a real Chrome window you
# open and log into yourself; see README for the Chrome remote-debugging setup)
NAICS_CODES=23,237,2362,2373,2379
MODIFIED_DATE_LOOKBACK_DAYS=30
CDP_URL=http://localhost:9222

# Excel output (defaults to the script's own folder)
EXCEL_OUTPUT_PATH=./sam_construction_awards.xlsx

# Email notifications - disabled by default. Works with any SMTP provider
# (Gmail, Microsoft 365 / ace-consulting.net, etc.) - set EMAIL_ENABLED=true
# and fill in the rest once you have credentials/app password ready.
EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USE_SSL=true
EMAIL_ADDRESS=your_address@example.com
EMAIL_PASSWORD=your_app_password_here
NOTIFY_EMAIL_TO=recipient@example.com

# Logging
LOG_LEVEL=INFO
LOG_PATH=./sam_automation.log
